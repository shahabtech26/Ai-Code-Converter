# CodeAlchemy Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# JWT Secret — use a long random string (at least 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_123

# JWT Expiry
JWT_EXPIRES_IN=7d

# OpenAI API Key (optional — leave empty to use pattern-based fallback)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
